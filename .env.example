# App
COSTOPT_ENVIRONMENT=development
COSTOPT_DEBUG=true
COSTOPT_SECRET_KEY=change-me-to-a-random-secret

# Database (SQLite by default — no Postgres needed for local dev)
COSTOPT_DATABASE_URL=sqlite+aiosqlite:///./costoptimizer.db
# For production: pip install -e ".[postgres]" and use:
# COSTOPT_DATABASE_URL=postgresql+asyncpg://costopt:costopt@localhost:5432/costoptimizer

# Redis (optional — only needed for Celery background workers)
# COSTOPT_REDIS_URL=redis://localhost:6379/0
# COSTOPT_CELERY_BROKER_URL=redis://localhost:6379/1
# COSTOPT_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AWS (for cross-account access)
COSTOPT_AWS_EXTERNAL_ID_PREFIX=costopt

# Azure (service principal for your SaaS app)
COSTOPT_AZURE_TENANT_ID=
COSTOPT_AZURE_CLIENT_ID=
COSTOPT_AZURE_CLIENT_SECRET=

# GCP
COSTOPT_GCP_CREDENTIALS_PATH=

# Anthropic (optional — template fallbacks work without it)
# pip install -e ".[llm]" to enable, then set your key:
COSTOPT_ANTHROPIC_API_KEY=
COSTOPT_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Features
COSTOPT_ENABLE_AUTO_REMEDIATION=false
COSTOPT_ENABLE_ML_PREDICTIONS=true
